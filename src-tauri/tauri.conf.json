{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Glance",
    "version": "0.2.0",
    "identifier": "com.vcloud.glance",
    "build": {
        "beforeDevCommand": "yarn vite:dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "yarn vite:build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "label": "settings",
                "title": "Glance - 设置",
                "url": "settings.html",
                "width": 460,
                "height": 530,
                "center": true,
                "visible": false,
                "resizable": false,
                "maximizable": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "nsis"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "installMode": "currentUser"
            }
        }
    }
}